{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/cron-notify",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/admin/payments/approve", "destination": "/api/admin/approve-payment" },
    { "source": "/api/admin/payments/reject", "destination": "/api/admin/reject-payment" },
    { "source": "/api/admin-subscriptions", "destination": "/api/admin/subscriptions" },
    { "source": "/api/eth-price",    "destination": "/api/etherscan?tool=eth-price" },
    { "source": "/api/ai-analysis", "destination": "/api/etherscan?tool=ai-analysis" },
    { "source": "/api/intelligence/detect-project", "destination": "/api/calendar/detect-project" },
    { "source": "/api/mint/readiness", "destination": "/api/calendar/mint-readiness" },
    { "source": "/api/mint/prewarm", "destination": "/api/calendar/mint-prewarm" },
    { "source": "/api/mint/prepare", "destination": "/api/calendar/mint-prepare" },
    { "source": "/api/mint/enable-strike", "destination": "/api/calendar/mint-enable-strike" },
    { "source": "/api/mint/stop", "destination": "/api/calendar/mint-stop" },
    { "source": "/api/mint/execute", "destination": "/api/calendar/mint-execute" },
    { "source": "/api/mint/confirm", "destination": "/api/calendar/mint-confirm" },
    { "source": "/api/mint/status", "destination": "/api/calendar/mint-status" },
    { "source": "/api/mint/strike-simulate", "destination": "/api/calendar/mint-strike-simulate" },
    { "source": "/api/mint/strike-replay", "destination": "/api/calendar/mint-strike-replay" },
    { "source": "/api/mint/strike-rerun", "destination": "/api/calendar/mint-strike-rerun" },
    { "source": "/api/vault/create", "destination": "/api/calendar/vault-create" },
    { "source": "/api/vault/import", "destination": "/api/calendar/vault-import" },
    { "source": "/api/vault/list", "destination": "/api/calendar/vault-list" },
    { "source": "/api/vault/withdraw", "destination": "/api/calendar/vault-withdraw" },
    { "source": "/api/capture/proxy", "destination": "/api/calendar/capture-proxy" },
    { "source": "/api/capture/save", "destination": "/api/calendar/capture-save" },
    { "source": "/api/capture/list", "destination": "/api/calendar/capture-list" },
    { "source": "/api/capture/stats", "destination": "/api/calendar/capture-stats" },
    { "source": "/api/capture/delete", "destination": "/api/calendar/capture-delete" },
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ]
}
