{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron-notify", "schedule": "*/5 * * * *" },
    { "path": "/api/whale-poll", "schedule": "*/5 * * * *" },
    { "path": "/api/auto-mint", "schedule": "* * * * *" }
  ]
}
